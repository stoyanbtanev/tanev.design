---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { navLinks, packages, valueCards } from "../content/site";
import og from "../assets/ogpreview.png";
import banner from "../assets/repo-banner.svg";
---

<BaseLayout
  title="tanev.design - Fast websites that launch in days"
  description="Fast, conversion-focused websites and instant website audits built and delivered in days."
  canonical="https://tanev.design/"
  ogImage="https://tanev.design/ogpreview.png"
>
  <header class="sticky top-0 z-40 border-b border-white/10 bg-[#070a12]/85 backdrop-blur-xl">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
      <a href="#" class="text-lg font-extrabold tracking-tight">tanev<span class="text-rose-400">.design</span></a>
      <ul class="hidden items-center gap-7 text-sm text-slate-300 md:flex">
        {
          navLinks.map((link) => (
            <li><a href={link.href} class="transition hover:text-white">{link.label}</a></li>
          ))
        }
      </ul>
      <a href="#contact" class="glass rounded-full px-4 py-2 text-xs font-semibold">Start a project</a>
    </nav>
  </header>

  <main class="relative z-10">
    <section class="mx-auto grid min-h-[90svh] max-w-6xl items-center gap-10 px-5 py-20 lg:grid-cols-[1.1fr_0.9fr]" data-parallax-wrap>
      <div data-reveal>
        <p class="mb-4 text-xs uppercase tracking-[0.22em] text-cyan-200">Fast websites. Fair prices.</p>
        <h1 class="kinetic text-5xl sm:text-7xl">
          Your <span class="gradient-text">vision.</span><br />
          <span class="text-rose-400">Brought to life.</span>
        </h1>
        <p class="muted mt-6 max-w-xl text-base leading-relaxed">
          I build beautiful, fast websites that help your business grow without the agency overhead.
          This Astro rebuild keeps static sections zero-JS and hydrates only interactive islands.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#pricing" class="rounded-xl bg-white px-5 py-3 text-sm font-semibold text-black">See Packages</a>
          <a href="#audit" class="glass rounded-xl px-5 py-3 text-sm font-semibold">Run Free Audit</a>
        </div>
      </div>
      <div data-parallax class="space-y-4" data-reveal>
        <div class="hero-orb glass skeuo rounded-3xl p-8">
          <div class="orb-core" aria-hidden="true"></div>
          <p class="mt-6 text-xs uppercase tracking-[0.2em] text-cyan-100">Interactive visual identity</p>
          <p class="muted mt-2 text-sm">No heavy runtime libraries on first load. Motion is CSS-driven and GPU-friendly.</p>
        </div>
        <div class="glass skeuo rounded-2xl p-4">
          <p class="text-xs uppercase tracking-[0.2em] text-cyan-200">Audit Snapshot</p>
          <p class="mt-2 text-2xl font-bold">Fast signal. Clear next step.</p>
          <p class="muted mt-2 text-sm">Static-first layout with optional enhanced interactions.</p>
        </div>
      </div>
    </section>

    <section id="audit" class="mx-auto max-w-4xl px-5 pb-20" data-reveal>
      <div class="glass skeuo rounded-3xl p-6 sm:p-8">
        <p class="text-xs uppercase tracking-[0.2em] text-slate-300">Free Instant Website Audit</p>
        <form class="mt-4 grid gap-3 sm:grid-cols-[1fr_auto]" aria-label="Website audit form">
          <input class="rounded-xl border border-white/15 bg-black/20 px-4 py-3" type="url" placeholder="https://yourwebsite.com" />
          <button class="rounded-xl bg-white px-6 py-3 text-sm font-semibold text-black">Run Free Audit</button>
        </form>
        <p class="muted mt-3 text-xs">No account needed. Results in seconds.</p>
      </div>
    </section>

    <section id="services" class="mx-auto max-w-6xl px-5 py-12">
      <div class="mb-8" data-reveal>
        <p class="text-xs uppercase tracking-[0.2em] text-cyan-200">Why Work With Me</p>
        <h2 class="section-title mt-3 font-extrabold">Hi, I am Stoyan. I build websites that actually work.</h2>
      </div>
      <div class="bento">
        {
          valueCards.map((card, idx) => (
            <article class={`glass skeuo lift rounded-2xl p-6 ${idx < 2 ? "md:col-span-6" : "md:col-span-4"}`} data-reveal>
              <h3 class="text-xl font-bold">{card.title}</h3>
              <p class="muted mt-3 text-sm leading-relaxed">{card.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-5 py-14">
      <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
        <article class="glass skeuo rounded-2xl p-6" data-reveal>
          <p class="text-xs uppercase tracking-[0.2em] text-cyan-200">The Reality</p>
          <h2 class="section-title mt-3 font-extrabold">Your business needs a digital home.</h2>
          <p class="muted mt-3 text-sm leading-relaxed">
            Social media pages are useful, but you do not own them. A fast and credible website is your controlled
            digital asset, open 24/7, turning passing interest into paying clients.
          </p>
        </article>
        <article class="glass skeuo rounded-2xl p-6" data-reveal>
          <p class="text-xs uppercase tracking-[0.2em] text-cyan-200">AI Assistant</p>
          <h3 class="mt-2 text-2xl font-bold">tanev.design AI</h3>
          <p class="muted mt-3 text-sm">Ask about project scope, pricing, and launch timeline through a secure serverless proxy.</p>
          <button class="mt-4 rounded-xl border border-white/20 px-4 py-2 text-xs">Open Chat (island-ready)</button>
        </article>
      </div>
    </section>

    <section id="pricing" class="mx-auto max-w-6xl px-5 py-20">
      <div class="mb-10 text-center" data-reveal>
        <p class="text-xs uppercase tracking-[0.2em] text-cyan-200">Packages</p>
        <h2 class="section-title mt-3 font-extrabold">Clear pricing. No surprises.</h2>
      </div>
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {
          packages.map((pack, idx) => (
            <article class={`glass skeuo lift rounded-2xl p-6 ${idx === 2 ? "border-rose-300/70" : ""}`} data-reveal>
              <h3 class="text-lg font-bold">{pack.name}</h3>
              <p class="mt-1 text-rose-300">{pack.price}</p>
              <p class="muted mt-3 text-sm">{pack.blurb}</p>
              <ul class="muted mt-4 space-y-2 text-xs">
                {pack.items.map((i) => <li>• {i}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <section id="contact" class="mx-auto grid max-w-6xl gap-8 px-5 pb-20 lg:grid-cols-2">
      <div data-reveal>
        <p class="text-xs uppercase tracking-[0.2em] text-cyan-200">Ready to start?</p>
        <h2 class="section-title mt-3 font-extrabold">Let us build something beautiful together.</h2>
        <p class="muted mt-3 max-w-xl text-sm">Drop a message and I will reply today. Plovdiv, Bulgaria. Available worldwide.</p>
        <div class="mt-5 space-y-2 text-sm text-slate-200">
          <p>Email: <a href="mailto:stoyanbtanev@gmail.com">stoyanbtanev@gmail.com</a></p>
          <p>Phone: <a href="tel:+359895469386">+359 895 469 386</a></p>
        </div>
      </div>
      <form class="glass skeuo rounded-2xl p-6" data-reveal>
        <label class="mb-2 block text-xs uppercase tracking-wide text-slate-300">Your Name</label>
        <input class="mb-4 w-full rounded-xl border border-white/15 bg-black/20 px-4 py-3" required />
        <label class="mb-2 block text-xs uppercase tracking-wide text-slate-300">Email</label>
        <input type="email" class="mb-4 w-full rounded-xl border border-white/15 bg-black/20 px-4 py-3" required />
        <label class="mb-2 block text-xs uppercase tracking-wide text-slate-300">Message</label>
        <textarea rows="4" class="mb-5 w-full rounded-xl border border-white/15 bg-black/20 px-4 py-3" required></textarea>
        <button class="w-full rounded-xl bg-white px-5 py-3 text-sm font-semibold text-black">Send Message</button>
      </form>
    </section>

    <section class="mx-auto max-w-4xl px-5 pb-20" data-reveal>
      <div class="glass skeuo rounded-2xl p-5">
        <p class="text-sm font-semibold">Cookie & Privacy Consent</p>
        <p class="muted mt-2 text-xs">Essential and analytics cookies can be enabled with clear, revokable consent.</p>
        <div class="mt-4 flex gap-2">
          <button class="rounded-lg bg-white px-3 py-2 text-xs font-semibold text-black">Accept All</button>
          <button class="rounded-lg border border-white/20 px-3 py-2 text-xs">Essential Only</button>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-5 pb-16" data-reveal>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="glass rounded-2xl p-4">
          <Image src={banner} alt="tanev.design repository banner" loading="lazy" />
        </div>
        <div class="glass rounded-2xl p-4">
          <Image src={og} alt="Social preview image" loading="lazy" />
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-white/10 px-5 py-8 text-center text-xs text-slate-400">
    <p>© {new Date().getFullYear()} Stoyan Tanev. All rights reserved.</p>
  </footer>

  <script>
    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in");
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.14 });
      document.querySelectorAll("[data-reveal]").forEach((el) => observer.observe(el));
    } else {
      document.querySelectorAll("[data-reveal]").forEach((el) => el.classList.add("in"));
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "tanev.design",
      "url": "https://tanev.design",
      "image": "https://tanev.design/ogpreview.png",
      "description": "Fast, conversion-focused websites and instant website audits built and delivered in days.",
      "areaServed": ["Bulgaria", "Worldwide"],
      "priceRange": "EUR 200 - EUR 800+",
      "founder": {
        "@type": "Person",
        "name": "Stoyan Tanev"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Plovdiv",
        "addressCountry": "BG"
      },
      "sameAs": [
        "https://www.linkedin.com/in/stoyan-tanev-a732603b8/",
        "https://github.com/stoyanbtanev"
      ],
      "email": "stoyanbtanev@gmail.com",
      "telephone": "+359895469386"
    }
  </script>
</BaseLayout>
